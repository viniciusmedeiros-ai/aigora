---
// TODO: Após criar o formulário no MailerLite, substitua o valor abaixo pelo
// seu Account ID real. Encontre em: MailerLite → Forms → seu formulário → Embed.
const MAILERLITE_ACCOUNT = 'SEU_ACCOUNT_ID_AQUI';
---

<div class="w-full">
  <!-- Formulário HTML puro — integra com MailerLite via fetch -->
  <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 w-full max-w-md mx-auto">
    <input
      type="email"
      name="email"
      required
      placeholder="seu@email.com"
      class="flex-1 rounded-lg border border-slate-600 bg-slate-800 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors"
    />
    <button
      type="submit"
      class="rounded-lg bg-brand-gradient px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 hover:opacity-90 transition-opacity whitespace-nowrap"
    >
      Quero receber
    </button>
  </form>

  <p id="form-message" class="mt-3 text-center text-sm hidden"></p>

  <p class="mt-3 text-center text-xs text-slate-500">
    Quinzenal · sem spam · cancele quando quiser
  </p>
</div>

<script define:vars={{ MAILERLITE_ACCOUNT }}>
  const form = document.getElementById('newsletter-form');
  const msg = document.getElementById('form-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = form.querySelector('input[name="email"]').value;
    const btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Enviando...';

    try {
      // Integração via MailerLite API v2 (substitua o group ID abaixo)
      // Group ID: encontre em MailerLite → Subscribers → Groups → seu grupo
      const res = await fetch(`https://connect.mailerlite.com/api/subscribers`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${MAILERLITE_ACCOUNT}`,
        },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        msg.textContent = 'Inscrito com sucesso! Até a próxima quinzena.';
        msg.className = 'mt-3 text-center text-sm text-emerald-400';
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      msg.textContent = 'Algo deu errado. Tente novamente em instantes.';
      msg.className = 'mt-3 text-center text-sm text-red-400';
    } finally {
      msg.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Quero receber';
    }
  });
</script>
