---
// Formulário oficial MailerLite embed — sem API key exposta
// ID: 9FTj2w — configurado em MailerLite → Forms → Embedded forms
---

<div class="w-full ml-form-wrapper">
  <div class="ml-embedded" data-form="9FTj2w"></div>
  <p class="mt-3 text-center text-xs text-slate-500">
    Quinzenal · sem spam · cancele quando quiser
  </p>
</div>

<style is:global>
  /* Adapta o embed do MailerLite ao tema escuro */
  .ml-form-wrapper .ml-embedded {
    width: 100%;
  }
  .ml-form-wrapper .ml-subscribe-form {
    background: transparent !important;
    padding: 0 !important;
  }
  .ml-form-wrapper .ml-field-group input {
    background: rgb(30 41 59) !important;
    border-color: rgb(71 85 105) !important;
    color: rgb(241 245 249) !important;
    border-radius: 0.5rem !important;
  }
  .ml-form-wrapper .ml-field-group input::placeholder {
    color: rgb(100 116 139) !important;
  }
  .ml-form-wrapper .ml-subscribe-button button {
    background: linear-gradient(135deg, #6366F1 0%, #0EA5E9 100%) !important;
    border-radius: 0.5rem !important;
    font-weight: 600 !important;
  }
</style>
