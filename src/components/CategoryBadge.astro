---
interface Props {
  categoria: string;
  size?: 'sm' | 'md';
}

const { categoria, size = 'md' } = Astro.props;

const map: Record<string, { label: string; color: string }> = {
  'claude':       { label: 'Claude',          color: '#E6007E' },
  'novas-ias':    { label: 'Novas IAs',        color: '#00BCD4' },
  'atualizacoes': { label: 'Atualizações',     color: '#00E676' },
  'mcps':         { label: 'MCPs',             color: '#fc6423' },
  'agents':       { label: 'Skills & Agents',  color: '#f509dd' },
};

const { label, color } = map[categoria] ?? { label: categoria, color: '#b3b3b3' };
const sizeClasses = size === 'sm' ? 'text-[10px] px-2 py-0.5' : 'text-[10px] px-2.5 py-1';
---

<span
  class={`inline-flex items-center font-bold uppercase tracking-widest rounded-full border ${sizeClasses}`}
  style={`color: ${color}; border-color: ${color}33; background-color: ${color}15;`}
>
  {label}
</span>
