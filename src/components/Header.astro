---
const nav = [
  { label: 'Início',         href: '/' },
  { label: 'Claude',         href: '/categoria/claude' },
  { label: 'Novas IAs',      href: '/categoria/novas-ias' },
  { label: 'Atualizações',   href: '/categoria/atualizacoes' },
  { label: 'MCPs',           href: '/categoria/mcps' },
  { label: 'Skills & Agents',href: '/categoria/agents' },
];

const current = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-[rgba(255,255,255,0.08)] bg-[#151515]/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6">
    <!-- Logo -->
    <div class="flex items-center gap-3 shrink-0">
      <a href="https://hagens.com.br" target="_blank" rel="noopener noreferrer">
        <img src="/hagens-logo.svg" alt="Hagens" class="h-7 w-auto" />
      </a>
      <span class="text-[#b3b3b3]/40 text-sm font-light">×</span>
      <a href="/">
        <img src="/logo.svg" alt="AIgora" class="h-10 w-auto" />
      </a>
    </div>

    <!-- Nav desktop -->
    <nav class="hidden lg:flex items-center gap-1">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class={`rounded-md px-3 py-1.5 text-xs uppercase tracking-widest font-light transition-colors ${
            current === href || (href !== '/' && current.startsWith(href))
              ? 'text-[#00BCD4]'
              : 'text-white hover:text-[#00BCD4]'
          }`}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- CTA newsletter -->
    <a
      href="/newsletter"
      class="hidden sm:inline-flex items-center gap-1.5 rounded-full border border-[#00BCD4] px-5 py-2 text-xs font-bold uppercase tracking-widest text-[#00BCD4] hover:bg-[#00BCD4] hover:text-white transition-all duration-300"
    >
      Newsletter
    </a>

    <!-- Mobile menu button -->
    <button id="menu-btn" class="lg:hidden rounded-md p-2 text-[#b3b3b3] hover:text-white transition-colors" aria-label="Menu">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-menu" class="hidden lg:hidden border-t border-[rgba(255,255,255,0.08)] px-4 py-3 flex-col gap-1">
    {nav.map(({ label, href }) => (
      <a
        href={href}
        class={`block rounded-md px-3 py-2 text-xs uppercase tracking-widest font-light transition-colors ${
          current === href || (href !== '/' && current.startsWith(href))
            ? 'text-[#00BCD4]'
            : 'text-white hover:text-[#00BCD4]'
        }`}
      >
        {label}
      </a>
    ))}
    <a href="/newsletter" class="mt-2 block rounded-full border border-[#00BCD4] px-3 py-2 text-xs font-bold uppercase tracking-widest text-[#00BCD4] text-center hover:bg-[#00BCD4] hover:text-white transition-all duration-300">
      Newsletter quinzenal
    </a>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
