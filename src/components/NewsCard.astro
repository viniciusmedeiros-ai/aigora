---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  date: Date;
  categoria: string;
  fonte: string;
  resumo: string;
  slug: string;
  imagem?: string;
  destaque?: boolean;
}

const { title, date, categoria, fonte, resumo, slug, imagem, destaque = false } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
}).format(date);

// Placeholder por categoria quando não há imagem
const placeholders: Record<string, string> = {
  'llms':             '/placeholders/llms.svg',
  'ferramentas':      '/placeholders/ferramentas.svg',
  'claude-anthropic': '/placeholders/claude.svg',
  'marketing-ia':     '/placeholders/marketing.svg',
  'atualizacoes':     '/placeholders/atualizacoes.svg',
  'tutoriais':        '/placeholders/tutoriais.svg',
};
const imgSrc = imagem || placeholders[categoria] || '/placeholders/llms.svg';
---

<article class={`group flex flex-col rounded-xl border overflow-hidden transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/30 ${destaque ? 'border-indigo-500/40 bg-gradient-to-br from-indigo-500/10 to-cyan-500/10' : 'border-slate-700/60 bg-slate-800/60 hover:border-slate-600/80'}`}>

  <!-- Imagem -->
  <a href={`/noticias/${slug}`} class="block overflow-hidden" tabindex="-1" aria-hidden="true">
    <img
      src={imgSrc}
      alt={title}
      width="640"
      height="360"
      loading="lazy"
      decoding="async"
      class="w-full h-44 object-cover transition-transform duration-300 group-hover:scale-105"
      onerror={`this.src='${placeholders[categoria] || '/placeholders/llms.svg'}'`}
    />
  </a>

  <!-- Categoria + data -->
  <div class="flex items-center justify-between px-5 pt-4 pb-2">
    <CategoryBadge categoria={categoria} size="sm" />
    <time class="text-xs text-slate-500" datetime={date.toISOString()}>{formattedDate}</time>
  </div>

  <!-- Título e resumo -->
  <div class="flex-1 px-5 pb-4">
    <a href={`/noticias/${slug}`} class="block">
      <h2 class={`font-semibold leading-snug transition-colors group-hover:text-indigo-300 ${destaque ? 'text-lg text-white' : 'text-base text-slate-100'}`}>
        {title}
      </h2>
    </a>
    <p class="mt-2 text-sm text-slate-400 line-clamp-2">{resumo}</p>
  </div>

  <!-- Fonte -->
  <div class="flex items-center justify-between border-t border-slate-700/50 px-5 py-3">
    <span class="text-xs text-slate-500">{fonte}</span>
    <a href={`/noticias/${slug}`} class="text-xs font-medium text-indigo-400 hover:text-indigo-300 transition-colors">
      Ler mais →
    </a>
  </div>
</article>
