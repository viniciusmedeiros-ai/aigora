---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  date: Date;
  categoria: string;
  fonte: string;
  resumo: string;
  slug: string;
  destaque?: boolean;
}

const { title, date, categoria, fonte, resumo, slug, destaque = false } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
}).format(date);
---

<article class={`group flex flex-col rounded-xl border transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-black/30 ${destaque ? 'border-indigo-500/40 bg-gradient-to-br from-indigo-500/10 to-cyan-500/10' : 'border-slate-700/60 bg-slate-800/60 hover:border-slate-600/80'}`}>
  <!-- Categoria + data -->
  <div class="flex items-center justify-between px-5 pt-5 pb-3">
    <CategoryBadge categoria={categoria} size="sm" />
    <time class="text-xs text-slate-500" datetime={date.toISOString()}>{formattedDate}</time>
  </div>

  <!-- Título -->
  <div class="flex-1 px-5 pb-4">
    <a href={`/noticias/${slug}`} class="block">
      <h2 class={`font-semibold leading-snug transition-colors group-hover:text-indigo-300 ${destaque ? 'text-lg text-white' : 'text-base text-slate-100'}`}>
        {title}
      </h2>
    </a>
    <p class="mt-2 text-sm text-slate-400 line-clamp-3">{resumo}</p>
  </div>

  <!-- Fonte -->
  <div class="flex items-center justify-between border-t border-slate-700/50 px-5 py-3">
    <span class="text-xs text-slate-500">{fonte}</span>
    <a href={`/noticias/${slug}`} class="text-xs font-medium text-indigo-400 hover:text-indigo-300 transition-colors">
      Ler mais →
    </a>
  </div>
</article>
