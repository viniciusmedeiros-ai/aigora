---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  date: Date;
  categoria: string;
  fonte: string;
  resumo: string;
  slug: string;
  imagem?: string;
  destaque?: boolean;
}

const { title, date, categoria, fonte, resumo, slug, imagem, destaque = false } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
}).format(date);

const placeholders: Record<string, string> = {
  'claude':       '/placeholders/claude.svg',
  'novas-ias':    '/placeholders/llms.svg',
  'atualizacoes': '/placeholders/atualizacoes.svg',
  'mcps':         '/placeholders/ferramentas.svg',
  'agents':       '/placeholders/tutoriais.svg',
};
const imgSrc = imagem || placeholders[categoria] || '/placeholders/llms.svg';
---

<article class="group flex flex-col rounded-2xl border border-[rgba(255,255,255,0.08)] bg-[#0a0a0a] overflow-hidden transition-all duration-300 hover:scale-[1.02] hover:border-[rgba(255,255,255,0.18)] hover:shadow-2xl">

  <!-- Imagem -->
  <a href={`/noticias/${slug}`} class="block overflow-hidden" tabindex="-1" aria-hidden="true">
    <img
      src={imgSrc}
      alt={title}
      width="640"
      height="360"
      loading="lazy"
      decoding="async"
      class="w-full h-44 object-cover transition-transform duration-500 group-hover:scale-105"
      onerror={`this.src='${placeholders[categoria] || '/placeholders/llms.svg'}'`}
    />
  </a>

  <!-- Categoria + data -->
  <div class="flex items-center justify-between px-5 pt-4 pb-2">
    <CategoryBadge categoria={categoria} size="sm" />
    <time class="text-[10px] uppercase tracking-widest text-[#b3b3b3]/60" datetime={date.toISOString()}>{formattedDate}</time>
  </div>

  <!-- Título e resumo -->
  <div class="flex-1 px-5 pb-4">
    <a href={`/noticias/${slug}`} class="block">
      <h2 class="font-semibold text-base text-white leading-snug transition-colors group-hover:text-[#00BCD4]">
        {title}
      </h2>
    </a>
    <p class="mt-2 text-sm text-[#b3b3b3] line-clamp-2 leading-relaxed">{resumo}</p>
  </div>

  <!-- Fonte -->
  <div class="flex items-center justify-between border-t border-[rgba(255,255,255,0.06)] px-5 py-3">
    <span class="text-[10px] uppercase tracking-widest text-[#b3b3b3]/50">{fonte}</span>
    <a href={`/noticias/${slug}`} class="text-xs font-bold uppercase tracking-widest text-[#00BCD4] hover:text-white transition-colors">
      Ler →
    </a>
  </div>
</article>
