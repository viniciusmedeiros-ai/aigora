---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description = 'AIgora — as últimas notícias sobre IA, LLMs e ferramentas.',
  image = '/placeholders/llms.svg',
  type = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image.startsWith('http') ? image : new URL(image, Astro.site).toString();
const isHome = Astro.url.pathname === '/';

const schemaWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'AIgora',
  description: 'Notícias sobre IA, LLMs e ferramentas',
  url: Astro.site?.toString(),
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: `${Astro.site}?q={search_term_string}` },
    'query-input': 'required name=search_term_string',
  },
};

const schemaOrganization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'AIgora',
  url: Astro.site?.toString(),
  logo: new URL('/logo.svg', Astro.site).toString(),
  sameAs: [],
};
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth bg-[#151515]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#151515" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary meta -->
    <title>{title} | AIgora</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="AIgora" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="AIgora" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={`${title} | AIgora`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | AIgora`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD WebSite + Organization (apenas na home) -->
    {isHome && (
      <>
        <script type="application/ld+json" set:html={JSON.stringify(schemaWebSite)} />
        <script type="application/ld+json" set:html={JSON.stringify(schemaOrganization)} />
      </>
    )}

    <!-- Slot extra para schemas de páginas internas -->
    <slot name="head-extra" />

    <!-- Outfit font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet" />

    <!-- MailerLite Universal -->
    <script>
      (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
      .push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
      n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
      (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
      ml('account', '2257433');
    </script>
    <!-- End MailerLite Universal -->
  </head>

  <body class="min-h-screen bg-[#151515] text-white antialiased">
    <!-- Constellation background -->
    <canvas id="bg-canvas" style="position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;"></canvas>

    <div class="relative z-10">
      <Header />
      <main id="main-content">
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      (function() {
        var canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
        var ctx    = canvas.getContext('2d')!;
        var W: number, H: number;
        var COLORS = ['#E6007E', '#00BCD4', '#00E676', '#f509dd', '#ffff00'];
        var DOTS   = 130;
        var DIST   = 180;
        var dots: Array<{x:number;y:number;vx:number;vy:number;r:number;col:string}> = [];

        function resize() {
          W = canvas.width  = window.innerWidth;
          H = canvas.height = window.innerHeight;
        }

        function rand(min: number, max: number) { return min + Math.random() * (max - min); }

        function init() {
          dots = [];
          for (var i = 0; i < DOTS; i++) {
            var col = COLORS[Math.floor(Math.random() * COLORS.length)];
            dots.push({ x: rand(0, W), y: rand(0, H), vx: rand(-0.35, 0.35), vy: rand(-0.35, 0.35), r: rand(1.5, 3.0), col });
          }
        }

        function hex2rgb(hex: string) {
          var r = parseInt(hex.slice(1,3),16);
          var g = parseInt(hex.slice(3,5),16);
          var b = parseInt(hex.slice(5,7),16);
          return r+','+g+','+b;
        }

        function draw() {
          ctx.clearRect(0, 0, W, H);
          for (var i = 0; i < dots.length; i++) {
            var a = dots[i];
            a.x += a.vx;
            a.y += a.vy;
            if (a.x < -10) a.x = W + 10;
            if (a.x > W + 10) a.x = -10;
            if (a.y < -10) a.y = H + 10;
            if (a.y > H + 10) a.y = -10;

            for (var j = i + 1; j < dots.length; j++) {
              var b  = dots[j];
              var dx = a.x - b.x, dy = a.y - b.y;
              var d  = Math.sqrt(dx*dx + dy*dy);
              if (d < DIST) {
                var op = (1 - d / DIST) * 0.30;
                ctx.strokeStyle = 'rgba(' + hex2rgb(a.col) + ',' + op + ')';
                ctx.lineWidth   = 1.0;
                ctx.beginPath();
                ctx.moveTo(a.x, a.y);
                ctx.lineTo(b.x, b.y);
                ctx.stroke();
              }
            }

            // glow externo
            var grd = ctx.createRadialGradient(a.x, a.y, 0, a.x, a.y, a.r * 3);
            grd.addColorStop(0, 'rgba(' + hex2rgb(a.col) + ',0.6)');
            grd.addColorStop(1, 'rgba(' + hex2rgb(a.col) + ',0)');
            ctx.fillStyle = grd;
            ctx.beginPath();
            ctx.arc(a.x, a.y, a.r * 3, 0, Math.PI * 2);
            ctx.fill();

            // núcleo do ponto
            ctx.fillStyle = 'rgba(' + hex2rgb(a.col) + ',0.9)';
            ctx.beginPath();
            ctx.arc(a.x, a.y, a.r, 0, Math.PI * 2);
            ctx.fill();
          }
          requestAnimationFrame(draw);
        }

        window.addEventListener('resize', function() { resize(); init(); });
        resize();
        init();
        draw();
      })();
    </script>
  </body>
</html>
