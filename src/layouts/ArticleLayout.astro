---
import BaseLayout from './BaseLayout.astro';
import CategoryBadge from '../components/CategoryBadge.astro';

interface Props {
  title: string;
  date: Date;
  categoria: string;
  fonte: string;
  fonteUrl: string;
  resumo: string;
  imagem?: string;
}

const { title, date, categoria, fonte, fonteUrl, resumo, imagem } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('pt-BR', {
  weekday: 'long',
  day: '2-digit',
  month: 'long',
  year: 'numeric',
}).format(date);

const placeholders: Record<string, string> = {
  'claude':       '/placeholders/claude.svg',
  'novas-ias':    '/placeholders/llms.svg',
  'atualizacoes': '/placeholders/atualizacoes.svg',
  'mcps':         '/placeholders/ferramentas.svg',
  'agents':       '/placeholders/tutoriais.svg',
};
const imgSrc = imagem || placeholders[categoria] || '/placeholders/llms.svg';

const canonical = new URL(Astro.url.pathname, Astro.site);
const categoriaLabel: Record<string, string> = {
  'claude':       'Claude & Anthropic',
  'novas-ias':    'Novas IAs',
  'atualizacoes': 'Atualizações',
  'mcps':         'MCPs',
  'agents':       'Skills & Agents',
};

const schemaNewsArticle = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: title,
  description: resumo,
  image: imgSrc.startsWith('http') ? imgSrc : new URL(imgSrc, Astro.site).toString(),
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: { '@type': 'Organization', name: 'AIgora', url: Astro.site?.toString() },
  publisher: {
    '@type': 'Organization',
    name: 'AIgora',
    url: Astro.site?.toString(),
    logo: { '@type': 'ImageObject', url: new URL('/logo.svg', Astro.site).toString() },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical.toString() },
  isPartOf: { '@type': 'WebSite', name: 'AIgora', url: Astro.site?.toString() },
};

const schemaBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início',                   item: Astro.site?.toString() },
    { '@type': 'ListItem', position: 2, name: categoriaLabel[categoria],   item: new URL(`/categoria/${categoria}`, Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---

<BaseLayout title={title} description={resumo} image={imgSrc}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaNewsArticle)} slot="head-extra" />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} slot="head-extra" />

  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-12">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[10px] uppercase tracking-widest text-[#b3b3b3]/50 mb-10">
      <a href="/" class="hover:text-white transition-colors">Início</a>
      <span aria-hidden="true">/</span>
      <a href={`/categoria/${categoria}`} class="hover:text-white transition-colors">
        {categoriaLabel[categoria]}
      </a>
      <span aria-hidden="true">/</span>
      <span class="text-[#b3b3b3]/30 truncate max-w-xs">{title}</span>
    </nav>

    <!-- Header do artigo -->
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <CategoryBadge categoria={categoria} />
        <time class="text-[10px] uppercase tracking-widest text-[#b3b3b3]/50 capitalize" datetime={date.toISOString()}>{formattedDate}</time>
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold text-white leading-tight mb-4">{title}</h1>
      <p class="text-base text-[#b3b3b3] leading-relaxed">{resumo}</p>
    </header>

    <!-- Imagem de destaque -->
    <div class="mb-8 rounded-2xl overflow-hidden">
      <img
        src={imgSrc}
        alt={title}
        width="768"
        height="432"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="w-full h-64 sm:h-80 object-cover"
        onerror={`this.src='${placeholders[categoria] || '/placeholders/llms.svg'}'`}
      />
    </div>

    <!-- Divisor -->
    <div class="h-px bg-[rgba(0,188,212,0.30)] mb-10"></div>

    <!-- Conteúdo -->
    <div class="prose prose-invert max-w-none
      prose-headings:text-white prose-headings:font-bold prose-headings:tracking-tight
      prose-p:text-[#b3b3b3] prose-p:leading-relaxed
      prose-a:text-[#00BCD4] prose-a:no-underline hover:prose-a:text-white
      prose-strong:text-white
      prose-code:text-[#00BCD4] prose-code:bg-[#111] prose-code:rounded prose-code:px-1
    ">
      <slot />
    </div>

    <!-- Fonte original -->
    <div class="mt-12 rounded-2xl border border-[rgba(255,255,255,0.08)] bg-[#0a0a0a] p-5 flex items-center justify-between gap-4">
      <div>
        <p class="text-[10px] uppercase tracking-widest text-[#b3b3b3]/40 mb-1">Fonte original</p>
        <p class="text-sm font-semibold text-white">{fonte}</p>
      </div>
      <a
        href={fonteUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 rounded-full border border-[#00BCD4] px-5 py-2 text-xs font-bold uppercase tracking-widest text-[#00BCD4] hover:bg-[#00BCD4] hover:text-white transition-all duration-300"
      >
        Ver original →
      </a>
    </div>

    <div class="mt-8">
      <a href="/" class="text-[10px] uppercase tracking-widest text-[#b3b3b3]/50 hover:text-white transition-colors">← Voltar ao início</a>
    </div>
  </div>
</BaseLayout>
