---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BaseLayout
  title="Newsletter quinzenal"
  description="Receba o compilado das principais notícias sobre IA a cada quinzena — gratuito, sem spam."
>
  <div class="mx-auto max-w-2xl px-4 sm:px-6 py-16 sm:py-24 text-center">
    <!-- Ícone -->
    <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-500/20 to-cyan-500/20 border border-indigo-500/30 text-3xl">
      📬
    </div>

    <h1 class="text-2xl sm:text-4xl font-extrabold text-white leading-tight mb-4">
      IA quinzenal na sua caixa de entrada
    </h1>
    <p class="text-slate-400 text-base sm:text-lg leading-relaxed mb-10 max-w-lg mx-auto">
      A cada 15 dias, enviamos um compilado curado com as principais notícias do mundo de IA — novos modelos, ferramentas lançadas, práticas com Claude Code e aplicações para marketing.
    </p>

    <!-- Formulário -->
    <div class="rounded-2xl border border-slate-700 bg-slate-800/50 p-8">
      <NewsletterForm />
    </div>

    <!-- O que você recebe -->
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-4 text-left">
      {[
        { icon: '🤖', title: 'Novos modelos', desc: 'GPT, Claude, Gemini, Llama — o que mudou e o que importa para você' },
        { icon: '🛠️', title: 'Ferramentas', desc: 'Lançamentos e atualizações das principais ferramentas de IA do mercado' },
        { icon: '📈', title: 'Marketing com IA', desc: 'Aplicações práticas para quem trabalha com marketing e growth' },
      ].map(({ icon, title, desc }) => (
        <div class="rounded-xl border border-slate-700 bg-slate-800/40 p-5">
          <div class="text-2xl mb-3">{icon}</div>
          <h3 class="text-sm font-semibold text-slate-200 mb-1">{title}</h3>
          <p class="text-xs text-slate-500 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
