---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsCard from '../components/NewsCard.astro';

const todas = await getCollection('noticias');
const noticias = todas.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Todas as notícias" description="Arquivo completo de notícias sobre IA — AIgora">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-12">
    <div class="mb-10">
      <a href="/" class="text-[10px] uppercase tracking-widest text-[#b3b3b3]/50 hover:text-white transition-colors">← Início</a>
      <h1 class="mt-4 text-2xl sm:text-3xl font-bold text-white">Todas as notícias</h1>
      <p class="mt-1 text-[10px] uppercase tracking-widest text-[#b3b3b3]/50">{noticias.length} {noticias.length === 1 ? 'notícia' : 'notícias'}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {noticias.map((noticia) => (
        <NewsCard
          title={noticia.data.title}
          date={noticia.data.date}
          categoria={noticia.data.categoria}
          fonte={noticia.data.fonte}
          resumo={noticia.data.resumo}
          slug={noticia.slug}
          imagem={noticia.data.imagem}
          destaque={noticia.data.destaque}
        />
      ))}
    </div>
  </div>
</BaseLayout>
