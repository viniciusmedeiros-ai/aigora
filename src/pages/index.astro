---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsCard from '../components/NewsCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const todasNoticias = await getCollection('noticias');
const noticias = todasNoticias.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const destaque = noticias.find(n => n.data.destaque) ?? noticias[0];
const grid = noticias.filter(n => n.id !== destaque.id).slice(0, 9);

const categorias = [
  { label: 'Tudo',            href: '/' },
  { label: 'Claude',          href: '/categoria/claude' },
  { label: 'Novas IAs',       href: '/categoria/novas-ias' },
  { label: 'Atualizações',    href: '/categoria/atualizacoes' },
  { label: 'MCPs',            href: '/categoria/mcps' },
  { label: 'Skills & Agents', href: '/categoria/agents' },
];

const formattedDestaque = new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit', month: 'short', year: 'numeric',
}).format(destaque.data.date);
---

<BaseLayout title="As últimas do mundo IA" description="AIgora — notícias sobre IA, LLMs, ferramentas e práticas. Atualizado automaticamente.">

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-[rgba(255,255,255,0.08)]">
    <!-- Glows de fundo -->
    <div class="pointer-events-none absolute -top-40 -left-40 h-[500px] w-[500px] rounded-full bg-[#E6007E] opacity-[0.06] blur-3xl"></div>
    <div class="pointer-events-none absolute -top-20 right-0 h-[400px] w-[400px] rounded-full bg-[#00BCD4] opacity-[0.05] blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 py-16 sm:py-24">
      <div class="max-w-3xl">
        <!-- Tagline pill -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[rgba(255,255,255,0.10)] bg-[rgba(255,255,255,0.04)] px-4 py-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-[#E6007E] animate-pulse"></span>
          <span class="text-[10px] font-bold uppercase tracking-widest text-[#b3b3b3]">Atualizado a cada 6 horas</span>
        </div>

        <h1 class="text-4xl sm:text-6xl font-bold text-white leading-tight tracking-tight">
          As últimas do<br/>
          <span class="text-[#00BCD4]">mundo IA</span>
        </h1>
        <p class="mt-5 text-base sm:text-lg text-[#b3b3b3] max-w-xl leading-relaxed">
          Notícias sobre Claude, MCPs, Agents, novas IAs e muito mais.
        </p>
      </div>
    </div>
  </section>

  <!-- Destaque -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 pt-12">
    <div class="mb-6 flex items-center gap-3">
      <span class="h-px flex-1 bg-[rgba(255,255,255,0.06)]"></span>
      <span class="text-[10px] font-bold uppercase tracking-widest text-[#b3b3b3]/60">Destaque</span>
      <span class="h-px flex-1 bg-[rgba(255,255,255,0.06)]"></span>
    </div>

    <a href={`/noticias/${destaque.slug}`} class="group block rounded-2xl border border-[rgba(0,188,212,0.20)] bg-[#0a0a0a] p-6 sm:p-8 hover:border-[rgba(0,188,212,0.45)] hover:shadow-[0_0_40px_rgba(0,188,212,0.08)] transition-all duration-300">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-3">
            <span class="inline-flex items-center rounded-full border border-[rgba(0,188,212,0.30)] bg-[rgba(0,188,212,0.10)] px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-widest text-[#00BCD4]">
              Destaque
            </span>
            <time class="text-[10px] uppercase tracking-widest text-[#b3b3b3]/50">{formattedDestaque}</time>
          </div>
          <h2 class="text-xl sm:text-2xl font-bold text-white group-hover:text-[#00BCD4] transition-colors leading-snug">
            {destaque.data.title}
          </h2>
          <p class="mt-3 text-sm text-[#b3b3b3] line-clamp-2 sm:line-clamp-3 leading-relaxed">
            {destaque.data.resumo}
          </p>
        </div>
        <div class="shrink-0 self-end sm:self-center">
          <span class="inline-flex items-center gap-1.5 rounded-full border border-[#00BCD4] px-5 py-2 text-xs font-bold uppercase tracking-widest text-[#00BCD4] group-hover:bg-[#00BCD4] group-hover:text-white transition-all duration-300">
            Ler artigo →
          </span>
        </div>
      </div>
    </a>
  </section>

  <!-- Filtro de categorias -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 pt-10">
    <div class="flex items-center gap-2 overflow-x-auto pb-2 scrollbar-hide">
      {categorias.map(({ label, href }) => (
        <a
          href={href}
          class={`shrink-0 rounded-full border px-4 py-1.5 text-[10px] font-bold uppercase tracking-widest transition-all duration-300 ${
            href === '/'
              ? 'border-[#00BCD4] bg-[rgba(0,188,212,0.10)] text-[#00BCD4]'
              : 'border-[rgba(255,255,255,0.10)] text-[#b3b3b3] hover:border-[rgba(255,255,255,0.25)] hover:text-white'
          }`}
        >
          {label}
        </a>
      ))}
    </div>
  </section>

  <!-- Grid de notícias -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {grid.map((noticia) => (
        <NewsCard
          title={noticia.data.title}
          date={noticia.data.date}
          categoria={noticia.data.categoria}
          fonte={noticia.data.fonte}
          resumo={noticia.data.resumo}
          slug={noticia.slug}
          destaque={noticia.data.destaque}
        />
      ))}
    </div>

    {noticias.length > 10 && (
      <div class="mt-10 text-center">
        <a href="/arquivo" class="inline-flex rounded-full border border-[rgba(255,255,255,0.15)] px-6 py-2.5 text-xs font-bold uppercase tracking-widest text-[#b3b3b3] hover:border-white hover:text-white transition-all duration-300">
          Ver todas as notícias
        </a>
      </div>
    )}
  </section>

  <!-- CTA Newsletter -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 pb-16">
    <div class="relative overflow-hidden rounded-2xl bg-[#0a0a0a] border border-[rgba(0,188,212,0.20)] p-8 sm:p-12 text-center">
      <!-- Orbs decorativos -->
      <div class="pointer-events-none absolute top-0 right-0 w-64 h-64 rounded-full bg-[#00BCD4] opacity-[0.05] -mr-32 -mt-32 blur-3xl"></div>
      <div class="pointer-events-none absolute bottom-0 left-0 w-48 h-48 rounded-full bg-[#E6007E] opacity-[0.04] -ml-20 -mb-20 blur-3xl"></div>
      <div class="relative">
        <p class="text-[10px] font-bold uppercase tracking-widest text-[#b3b3b3] mb-3">Newsletter quinzenal</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">
          Sem tempo de acompanhar tudo?
        </h2>
        <p class="text-[#b3b3b3] mb-8 max-w-md mx-auto text-sm sm:text-base">
          Receba o compilado das principais notícias a cada quinzena — direto na sua caixa de entrada, sem spam.
        </p>
        <NewsletterForm />
      </div>
    </div>
  </section>
</BaseLayout>
