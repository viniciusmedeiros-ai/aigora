---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsCard from '../components/NewsCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const todasNoticias = await getCollection('noticias');
const noticias = todasNoticias.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const destaque = noticias.find(n => n.data.destaque) ?? noticias[0];
const grid = noticias.filter(n => n.id !== destaque.id).slice(0, 9);

const categorias = [
  { label: 'Tudo',      href: '/' },
  { label: 'LLMs',      href: '/categoria/llms' },
  { label: 'Ferramentas', href: '/categoria/ferramentas' },
  { label: 'Claude',    href: '/categoria/claude-anthropic' },
  { label: 'Marketing', href: '/categoria/marketing-ia' },
  { label: 'Atualizações', href: '/categoria/atualizacoes' },
  { label: 'Tutoriais', href: '/categoria/tutoriais' },
];

const formattedDestaque = new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit', month: 'short', year: 'numeric',
}).format(destaque.data.date);
---

<BaseLayout title="As últimas do mundo IA" description="AIgora — notícias sobre IA, LLMs, ferramentas e práticas em português. Atualizado automaticamente.">
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-slate-800">
    <!-- Glow de fundo -->
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-indigo-900/20 via-transparent to-cyan-900/10"></div>
    <div class="pointer-events-none absolute -top-32 -left-32 h-96 w-96 rounded-full bg-indigo-600/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -top-16 right-0 h-64 w-64 rounded-full bg-cyan-600/10 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 py-14 sm:py-20">
      <div class="max-w-3xl">
        <!-- Tagline -->
        <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-indigo-500/30 bg-indigo-500/10 px-3 py-1">
          <span class="h-1.5 w-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
          <span class="text-xs font-medium text-indigo-300">Atualizado automaticamente</span>
        </div>

        <h1 class="text-3xl sm:text-5xl font-extrabold text-white leading-tight tracking-tight">
          As últimas do<br/>
          <span class="bg-brand-gradient bg-clip-text text-transparent">mundo IA</span>
        </h1>
        <p class="mt-4 text-base sm:text-lg text-slate-400 max-w-xl leading-relaxed">
          Notícias sobre LLMs, ferramentas, Claude Code, Marketing com IA e muito mais — em português, atualizadas a cada 6 horas.
        </p>
      </div>
    </div>
  </section>

  <!-- Destaque -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 pt-10">
    <div class="mb-6 flex items-center gap-3">
      <span class="h-px flex-1 bg-slate-800"></span>
      <span class="text-xs font-semibold uppercase tracking-widest text-slate-500">Destaque</span>
      <span class="h-px flex-1 bg-slate-800"></span>
    </div>

    <a href={`/noticias/${destaque.slug}`} class="group block rounded-2xl border border-indigo-500/30 bg-gradient-to-br from-indigo-500/10 to-cyan-500/5 p-6 sm:p-8 hover:border-indigo-500/50 transition-all">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-3">
            <span class="inline-flex items-center rounded-full bg-indigo-500/20 border border-indigo-500/40 px-2.5 py-0.5 text-xs font-medium text-indigo-300">
              Destaque
            </span>
            <time class="text-xs text-slate-500">{formattedDestaque}</time>
          </div>
          <h2 class="text-xl sm:text-2xl font-bold text-white group-hover:text-indigo-200 transition-colors leading-snug">
            {destaque.data.title}
          </h2>
          <p class="mt-3 text-sm sm:text-base text-slate-400 line-clamp-2 sm:line-clamp-3 leading-relaxed">
            {destaque.data.resumo}
          </p>
        </div>
        <div class="shrink-0 self-end sm:self-center">
          <span class="inline-flex items-center gap-1.5 rounded-lg bg-indigo-500/15 border border-indigo-500/30 px-4 py-2 text-sm font-medium text-indigo-300 group-hover:bg-indigo-500/25 transition-colors">
            Ler artigo <span>→</span>
          </span>
        </div>
      </div>
    </a>
  </section>

  <!-- Filtro de categorias -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 pt-10">
    <div class="flex items-center gap-2 overflow-x-auto pb-2 scrollbar-hide">
      {categorias.map(({ label, href }) => (
        <a
          href={href}
          class={`shrink-0 rounded-full border px-4 py-1.5 text-sm font-medium transition-colors ${
            href === '/'
              ? 'border-indigo-500/50 bg-indigo-500/15 text-indigo-300'
              : 'border-slate-700 text-slate-400 hover:border-slate-600 hover:text-slate-200'
          }`}
        >
          {label}
        </a>
      ))}
    </div>
  </section>

  <!-- Grid de notícias -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {grid.map((noticia) => (
        <NewsCard
          title={noticia.data.title}
          date={noticia.data.date}
          categoria={noticia.data.categoria}
          fonte={noticia.data.fonte}
          resumo={noticia.data.resumo}
          slug={noticia.slug}
          destaque={noticia.data.destaque}
        />
      ))}
    </div>

    {noticias.length > 10 && (
      <div class="mt-8 text-center">
        <a href="/arquivo" class="inline-flex rounded-lg border border-slate-700 px-6 py-2.5 text-sm font-medium text-slate-400 hover:border-slate-600 hover:text-slate-200 transition-colors">
          Ver todas as notícias
        </a>
      </div>
    )}
  </section>

  <!-- CTA Newsletter -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 pb-16">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-indigo-600/20 to-cyan-600/10 border border-indigo-500/20 p-8 sm:p-12 text-center">
      <div class="pointer-events-none absolute inset-0 bg-brand-gradient-soft"></div>
      <div class="relative">
        <div class="mb-2 text-2xl">📬</div>
        <h2 class="text-xl sm:text-2xl font-bold text-white mb-2">
          Sem tempo de acompanhar tudo?
        </h2>
        <p class="text-slate-400 mb-8 max-w-md mx-auto text-sm sm:text-base">
          Receba o compilado das principais notícias a cada quinzena — direto na sua caixa de entrada, sem spam.
        </p>
        <NewsletterForm />
      </div>
    </div>
  </section>
</BaseLayout>
